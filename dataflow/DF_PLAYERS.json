{
	"name": "DF_PLAYERS",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SRC_PARQUET_DF",
						"type": "DatasetReference"
					},
					"name": "SourcePlayers"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TRGT_PLAYERS_GOALKEEPERS",
						"type": "DatasetReference"
					},
					"name": "SinkPlayerGoalKeepers"
				}
			],
			"transformations": [
				{
					"name": "FilterGoalkeepers"
				}
			],
			"scriptLines": [
				"source(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet') ~> SourcePlayers",
				"SourcePlayers filter(byName('position') == 'Goalkeeper') ~> FilterGoalkeepers",
				"FilterGoalkeepers sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SinkPlayerGoalKeepers"
			]
		}
	}
}