{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "quant-azure-data-factory"
		},
		"LS_ADLS_GEN2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_ADLS_GEN2'"
		},
		"LS_AZURE_SQL_DB_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AZURE_SQL_DB'"
		},
		"LS_ONPREM_SQL_SERVER_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_ONPREM_SQL_SERVER'"
		},
		"LS_ADLS_GEN2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://quantcloudstorage.dfs.core.windows.net/"
		},
		"LS_AZURE_SQL_DB_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "qctech.database.windows.net"
		},
		"LS_AZURE_SQL_DB_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "QuantCloudDB"
		},
		"LS_AZURE_SQL_DB_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "QuantUser"
		},
		"LS_ONPREM_SQL_SERVER_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "SandeepReddy"
		},
		"LS_ONPREM_SQL_SERVER_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AdventureWorks"
		},
		"LS_ONPREM_SQL_SERVER_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "AdfUser"
		},
		"EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_folder_path": {
			"type": "string",
			"defaultValue": "@replace(triggerBody().folderPath,'quant-container/','')"
		},
		"EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_file_name": {
			"type": "string",
			"defaultValue": "@triggerBody().fileName"
		},
		"EventBasedTriggerADLS_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/a8c62c57-2636-40f5-a753-24c196a04e1f/resourceGroups/rg-quantcloud-technologies/providers/Microsoft.Storage/storageAccounts/quantcloudstorage"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "quant-azure-data-factory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_ADLS_GEN2_accountKey": {
						"value": "[parameters('LS_ADLS_GEN2_accountKey')]"
					},
					"LS_AZURE_SQL_DB_password": {
						"value": "[parameters('LS_AZURE_SQL_DB_password')]"
					},
					"LS_ONPREM_SQL_SERVER_password": {
						"value": "[parameters('LS_ONPREM_SQL_SERVER_password')]"
					},
					"LS_ADLS_GEN2_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_GEN2_properties_typeProperties_url')]"
					},
					"LS_AZURE_SQL_DB_properties_typeProperties_server": {
						"value": "[parameters('LS_AZURE_SQL_DB_properties_typeProperties_server')]"
					},
					"LS_AZURE_SQL_DB_properties_typeProperties_database": {
						"value": "[parameters('LS_AZURE_SQL_DB_properties_typeProperties_database')]"
					},
					"LS_AZURE_SQL_DB_properties_typeProperties_userName": {
						"value": "[parameters('LS_AZURE_SQL_DB_properties_typeProperties_userName')]"
					},
					"LS_ONPREM_SQL_SERVER_properties_typeProperties_server": {
						"value": "[parameters('LS_ONPREM_SQL_SERVER_properties_typeProperties_server')]"
					},
					"LS_ONPREM_SQL_SERVER_properties_typeProperties_database": {
						"value": "[parameters('LS_ONPREM_SQL_SERVER_properties_typeProperties_database')]"
					},
					"LS_ONPREM_SQL_SERVER_properties_typeProperties_userName": {
						"value": "[parameters('LS_ONPREM_SQL_SERVER_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "quant-azure-data-factory_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_folder_path": {
						"value": "[parameters('EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_folder_path')]"
					},
					"EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_file_name": {
						"value": "[parameters('EventBasedTriggerADLS_properties_PL_EVENT_BASED_MIGRATION_parameters_file_name')]"
					},
					"EventBasedTriggerADLS_properties_typeProperties_scope": {
						"value": "[parameters('EventBasedTriggerADLS_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'quant-azure-data-factory_ArmTemplate_0')]"
			]
		}
	]
}