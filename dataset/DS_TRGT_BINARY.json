		},
		"parameters": {
			"trgt_file_name": {
				"type": "string"
			},
			"trgt_folder_name": {
				"type": "string"
			}
		},
		"folder": {
			"name": "ADLS"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().trgt_file_name",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('Processesed/', dataset().trgt_folder_name)",
					"type": "Expression"
				},
				"fileSystem": "quant-container"
			}
		}
	}
}